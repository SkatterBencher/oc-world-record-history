{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OC World Record",
  "type": "object",
  "required": [
    "uid",
    "category",
    "achieved_at",
    "value_mhz",
    "hardware",
    "overclockers",
    "sources",
    "tags",
    "verified"
  ],
  "properties": {
    "uid": {
      "type": "string",
      "pattern": "^[0-9]{8}_[0-9]+$",
      "description": "Unique identifier: YYYYMMDD_valueMHz (no decimals, floor)"
    },
    "category": {
      "type": "string",
      "enum": [
        "cpu",
        "gpu",
        "memory"
      ]
    },
    "subcategory": {
      "type": [
        "string",
        "null"
      ],
      "description": "e.g. ddr3, ddr4, ddr5 for memory; null for cpu/gpu"
    },
    "achieved_at": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date: YYYY-MM-DD"
    },
    "achieved_at_approximate": {
      "type": "boolean",
      "description": "true if only month/year is known, not the exact day"
    },
    "value_mhz": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "hardware": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "description": "The overclocked component, e.g. Intel Core i9-14900KF"
        },
        "motherboard": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory": {
          "type": [
            "string",
            "null"
          ]
        },
        "cooling": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "overclockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "handle"
        ],
        "properties": {
          "handle": {
            "type": "string"
          },
          "real_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "country": {
            "type": [
              "string",
              "null"
            ],
            "description": "ISO 3166-1 alpha-2"
          },
          "profile_url": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "url"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "archived_url": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "type"
        ],
        "properties": {
          "file": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "cpuz",
              "gpuz",
              "validation",
              "photo",
              "other"
            ]
          },
          "caption": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "verified": {
      "type": "boolean"
    },
    "submitted_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "hero": {
      "type": [
        "string",
        "null"
      ],
      "description": "Filename of the hero image shown in the detail panel"
    },
    "not_a_record": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Set to true to manually exclude this entry from the timeline. Add explanation in notes."
    }
  },
  "additionalProperties": false
}